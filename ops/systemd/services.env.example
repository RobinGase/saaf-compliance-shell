# /etc/saaf-shell/services.env — read by saaf-guardrails and saaf-router units.
# Copy this file to /etc/saaf-shell/services.env and edit for the target host.

# Where the shell repo is installed. Services set this as WorkingDirectory and
# invoke $SAAF_SHELL_ROOT/.venv/bin/python. Keep it persistent — /tmp is wiped
# on reboot and is only appropriate for dev workflows.
SAAF_SHELL_ROOT=/opt/saaf/shell

# Model endpoint the router forwards to. Router refuses everything else.
# Format: full chat-completions URL including /v1/chat/completions path.
LOCAL_NIM_URL=http://127.0.0.1:8000/v1/chat/completions

# Optional — passed through to the guardrails service if its loader reads it.
# OPENAI_API_KEY=not-used

# Audit-log retention (read by saaf-log-retention.service). 0 = disabled.
# Only rotated archives matching audit.jsonl.* are pruned; the live
# audit.jsonl is never touched. See docs/RUNBOOK.md "Disk pressure".
SAAF_AUDIT_LOG_DIR=/var/log/openshell
SAAF_AUDIT_RETENTION_DAYS=0
